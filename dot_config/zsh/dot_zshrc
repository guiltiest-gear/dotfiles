#!/bin/zsh
# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Remove annoying zinit aliases
declare -A ZINIT=([NO_ALIASES]=1)

# Set up zinit
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# Edit line in vim with ctrl-e
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^E' edit-command-line

# Trap USR1 signals to trigger a rehash
trap 'rehash' USR1

# Use fd to list path candidates
_fzf_compgen_path() {
  fd --hidden --follow --exclude ".git" . "$1"
}

# Use fd to generate the list for directory completion
_fzf_compgen_dir() {
  fd --type d --hidden --follow --exclude ".git" . "$1"
}

# Enable colors and change prompt:
autoload -U colors && colors

# vi mode
bindkey -v
# export KEYTIMEOUT=1

# Exports
export ABBR_QUIETER=1
export ABBR_SET_EXPANSION_CURSOR=1
export FZF_DEFAULT_OPTS="--no-mouse --cycle --tiebreak=chunk"
export FZF_DEFAULT_COMMAND='rg --files --hidden --smart-case --glob "!.git/*"'
export ZSH_AUTOSUGGEST_STRATEGY=(completion history)
export YSU_MESSAGE_POSITION="after"
export STARSHIP_CONFIG="$XDG_CONFIG_HOME"/starship/starship.toml
export ZSH_EVALCACHE_DIR="$XDG_CACHE_HOME"/zsh/evalcache

# Various options
setopt aliases
setopt complete_aliases
setopt glob_dots
setopt interactive_comments
setopt append_history
setopt hist_ignore_dups
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_find_no_dups
setopt hist_save_no_dups
setopt hist_expire_dups_first
setopt share_history

set-abbreviations() {
  if command -v pacman >/dev/null 2>&1; then
    abbr p='pacman'
    abbr sp='sudo pacman'
    abbr sps='sudo pacman -S'
    abbr pq='pacman -Q%'
    abbr pqi='pacman -Qi'
    abbr psi='pacman -Si'
    abbr pql='pacman -Ql'
    abbr pfl='pacman -Fl'
    abbr pss='pacman -Ss'
    abbr pqs='pacman -Qs'
    abbr pqe='pacman -Qe'
    abbr pqo='pacman -Qo'
    abbr spyu='sudo pacman -Syu'
    abbr spr='sudo pacman -Rns'
    abbr pa='paru'
    abbr pagp="paru -Gp"
  fi
  abbr g='git'
  command -v git-annex >/dev/null 2>&1 && abbr ga='git annex'
  command -v nvim >/dev/null 2>&1 && abbr v='nvim'
  if command -v chezmoi >/dev/null 2>&1; then
    abbr ch='chezmoi'
    abbr cha='chezmoi add'
    abbr chd='chezmoi diff'
    abbr che='chezmoi edit'
    abbr chap='chezmoi apply'
    abbr chg='chezmoi git'
    abbr chc='chezmoi cd'
    abbr chdx='chezmoi diff -x'
  fi
}

fzf-tab-zstyle-opts() {
  # Disable zsh menu completion
  zstyle ':completion:*' menu no
  # Ignore case completion
  zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
  # Set description format for fzf-tab group support
  zstyle ':completion:*:descriptions' format '[%d]'
  # Switch group using `<` and `>`
  zstyle ':fzf-tab:*' switch-group '<' '>'
  # Disable sort when completing git checkout
  zstyle ':completion:*:git-checkout:*' sort false
  # Preview directory content with eza when completing cd
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
  # Re-add style flags to fzf-tab
  zstyle ':fzf-tab:*' use-fzf-default-opts yes
  # Set other fzf flags
  zstyle ':fzf-tab:*' fzf-flags --scheme=path
}

# Plugins
zinit depth"1" light-mode for \
  mroth/evalcache

zinit wait lucid for \
  OMZP::cp \
  OMZP::sudo \
  atload"unalias x" OMZP::extract

zinit depth"1" wait lucid light-mode for \
  has"fzf" \
  atload"fzf-tab-zstyle-opts; unset -f fzf-tab-zstyle-opts" \
  Aloxaf/fzf-tab \
  atload"set-abbreviations; unset -f set-abbreviations" olets/zsh-abbr \
  MichaelAquilina/zsh-you-should-use \
  hlissner/zsh-autopair

zinit depth"1" wait lucid light-mode for \
  atinit"ZINIT[COMPINIT_OPTS]=-C; zicompinit; zicdreplay" \
  atload"unalias fsh-alias" \
  zdharma-continuum/fast-syntax-highlighting \
  blockf atpull"zinit creinstall -q ." \
  zsh-users/zsh-completions \
  atload"!_zsh_autosuggest_start" \
  zsh-users/zsh-autosuggestions

zinit depth"1" wait"0a" lucid light-mode for \
  has"git" \
  as"program" \
  pick"$ZPFX/bin/git-*" \
  src"etc/git-extras-completion.zsh" \
  make"PREFIX=$ZPFX" \
  tj/git-extras

# Load zoxide
command -v zoxide >/dev/null 2>&1 && _evalcache zoxide init zsh

# Starship prompt
command -v starship >/dev/null 2>&1 && _evalcache starship init zsh

# zsh keybindings for fzf
command -v fzf >/dev/null 2>&1 && _evalcache fzf --zsh

# Load in aliases from aliasrc
source "$ZDOTDIR"/aliasrc

# Enable transient prompt
source "$ZDOTDIR"/transient-prompt.zsh

# Insulter
source "$ZDOTDIR"/command-not-found.zsh

# fzf tokyonight colors
source "$XDG_DATA_HOME"/nvim/lazy/tokyonight.nvim/extras/fzf/tokyonight_night.sh

# Random color script
command -v colorscript >/dev/null 2>&1 && colorscript random
